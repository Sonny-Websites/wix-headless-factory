---
interface Props {
  title?: string;
}

const { title = "test" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href="/">test</a>
        <nav aria-label="Main">
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/faq">FAQ</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
  </body>
</html>

<style>
  :global(:root) {
    --pink-050: #fff3f9;
    --pink-100: #ffe6f2;
    --pink-200: #ffcde4;
    --pink-400: #ef5f9b;
    --pink-700: #8f1f54;
    --text-strong: #4e1a33;
  }

  :global(html),
  :global(body) {
    margin: 0;
    width: 100%;
    min-height: 100%;
    font-family: "Trebuchet MS", sans-serif;
    background: linear-gradient(180deg, var(--pink-050) 0%, var(--pink-100) 100%);
    color: var(--text-strong);
  }

  :global(a) {
    color: var(--pink-700);
  }

  .container {
    max-width: 60rem;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .site-header {
    border-bottom: 1px solid var(--pink-200);
    background: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
  }

  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 4rem;
  }

  .brand {
    text-decoration: none;
    color: var(--pink-700);
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  nav {
    display: flex;
    gap: 1rem;
  }

  nav a {
    color: var(--text-strong);
    text-decoration: none;
  }

  nav a:hover {
    color: var(--pink-400);
    text-decoration: underline;
  }
</style>
