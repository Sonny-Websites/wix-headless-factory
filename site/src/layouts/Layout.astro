---
interface Props {
  title?: string;
}

const { title = "test" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href="/">test</a>
        <nav aria-label="Main">
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/faq">FAQ</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    width: 100%;
    min-height: 100%;
    font-family: "Trebuchet MS", sans-serif;
    background: #f8f8f6;
    color: #1f2421;
  }

  .container {
    max-width: 60rem;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .site-header {
    border-bottom: 1px solid #d8ddd7;
    background: #ffffff;
    margin-bottom: 2rem;
  }

  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 4rem;
  }

  .brand {
    text-decoration: none;
    color: #1f2421;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  nav {
    display: flex;
    gap: 1rem;
  }

  nav a {
    color: #1f2421;
    text-decoration: none;
  }

  nav a:hover {
    text-decoration: underline;
  }
</style>
